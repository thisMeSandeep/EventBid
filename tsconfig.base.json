{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "paths": {
      "*": ["./../../*"],
      "@eventbid/server-schema": ["./apps/server/src/db/schema.ts"]
    }
  }
}
