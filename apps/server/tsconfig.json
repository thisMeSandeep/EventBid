{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["node"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "rootDir": "../..",
    "outDir": "./dist",
    "paths": {
      "@eventbid/server-schema": ["./src/db/schema.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "../../packages/shared/src/**/*.ts"],
  "exclude": ["node_modules", "drizzle.config.ts"]
}
