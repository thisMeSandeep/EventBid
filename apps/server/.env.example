DATABASE_URL=postgresql://postgres:password@localhost:5432/eventbid
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001

UPSTASH_REDIS_URL=rediss://default:password@example-redis.upstash.io:6379

BETTER_AUTH_SECRET=replace-with-a-strong-secret
BETTER_AUTH_URL=http://localhost:3000/api
GOOGLE_CLIENT_ID=example-google-client-id
GOOGLE_CLIENT_SECRET=example-google-client-secret

AI_GATEWAY_API_KEY=example-ai-gateway-key
AI_GATEWAY_BASE_URL=https://api.ai-gateway.example.com
AI_GENERATION_MODEL=anthropic/claude-sonnet-4.5
AI_EMBEDDING_MODEL=openai/text-embedding-3-small

RESEND_API_KEY=re_1234567890
EMAIL_FROM=noreply@eventbid.com

CLOUDINARY_CLOUD_NAME=eventbid-demo
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=cloudinary-secret

DATABASE_SSL=false
DATABASE_POOL_SIZE=10
DATABASE_IDLE_TIMEOUT=20
DATABASE_CONNECT_TIMEOUT=10
